# Required for live runs
MANTLE_RPC_URL=https://rpc.mantle.xyz

# Optional — used by fetchers
MANTLE_SUBGRAPH_URL=https://subgraph.mantle.xyz/subgraphs/name/mantle/tokens
GECKOTERMINAL_API_KEY=
DEFILLAMA_API_KEY=
DUNE_API_KEY=

# Required only for `--attest` (writes onchain via ERC-8004)
ERC8004_PRIVATE_KEY=
ERC8004_AGENT_ID=

# Optional — for the x402-gated server
X402_PRICE_ATOMIC=10000
X402_ASSET=
X402_PAYTO=
